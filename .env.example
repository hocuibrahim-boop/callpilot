APP_NAME=CallPilot
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://callpilot.ibo.dowaba.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=callpilot
DB_USERNAME=callpilot_user
DB_PASSWORD=

CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Verimor Santral Webhook
WEBHOOK_SECRET=

# Cron güvenlik anahtarı
CRON_SECRET=

# DoWaba WhatsApp (v2)
DOWABA_BASE_URL=
DOWABA_TOKEN=
DOWABA_SENDER=

# FCM Push (v1.1)
FCM_SERVER_KEY=
